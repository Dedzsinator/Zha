\@writefile{lof}{\select@language{magyar} \contentsline {figure}{\numberline {8.5.}{\ignorespaces Példa generálások kotta formátumban: (a) Csak Markov modell kimenete, strukturált de monoton; (b) Markov+VAE kombináció, kreatívabb harmóniák; (c) Teljes pipeline (Markov+VAE+Transformer), koherens és variált; (d) Multi track generálás (melody+bass/drums), teljes zenekari textúra. Mindegyikhez 8 től 16 ütem C dúr 4/4 ben.}}{68}{figure.caption.59}\protected@file@percent }
\newlabel{fig:generation_examples}{{8.5}{68}{Példa generálások kotta formátumban: (a) Csak Markov modell kimenete, strukturált de monoton; (b) Markov+VAE kombináció, kreatívabb harmóniák; (c) Teljes pipeline (Markov+VAE+Transformer), koherens és variált; (d) Multi track generálás (melody+bass/drums), teljes zenekari textúra. Mindegyikhez 8 től 16 ütem C dúr 4/4 ben}{figure.caption.59}{}}
